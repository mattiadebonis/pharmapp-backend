SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Comma-separated origins (JSON array). Wildcard '*' OK only in dev;
# the prod validator forbids it.
# Production example: ["https://pharmareminder.app","https://api.pharmareminder.app"]
CORS_ORIGINS=["*"]

# Comma-separated allowed Host headers (JSON array). Used by
# TrustedHostMiddleware. Wildcard '*' OK only in dev; prod must be
# concrete (validator enforces).
# Production: ["api.pharmareminder.app"]
ALLOWED_HOSTS=["*"]

ENVIRONMENT=development
LOG_LEVEL=INFO

# Set to true ONLY when behind a known proxy (Nginx/Fly.io/Cloudflare)
# that strips/sets X-Forwarded-For. Otherwise rate limiting can be
# spoofed by direct clients.
TRUST_PROXY_HEADER=false
